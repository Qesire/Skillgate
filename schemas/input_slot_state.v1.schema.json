{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skillgate:schema:input-slot-state:v1",
  "title": "SkillGate InputSlotState",
  "description": "Evaluation state for one target-skill input slot.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "text",
    "description",
    "category",
    "status",
    "value",
    "question",
    "assumption",
    "evidence_ids",
    "answer_source",
    "support",
    "risk",
    "ambiguity",
    "handling_reason",
    "confidence"
  ],
  "properties": {
    "schema_version": {
      "const": "skillgate.input_slot_state.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "enum": [
        "agent_discoverable",
        "blocked",
        "human_askable",
        "irrelevant",
        "known",
        "requires_authorization",
        "safe_assumption"
      ]
    },
    "status": {
      "enum": [
        "agent_discoverable",
        "blocked",
        "human_askable",
        "irrelevant",
        "known",
        "requires_authorization",
        "safe_assumption"
      ]
    },
    "value": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "question": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "assumption": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "answer_source": {
      "enum": [
        "agent",
        "authorization",
        "blocked",
        "human",
        "human_or_agent",
        "known",
        "policy_default"
      ]
    },
    "support": {
      "enum": [
        "explicit",
        "guessed",
        "inferred",
        "recommended"
      ]
    },
    "risk": {
      "type": "string",
      "minLength": 1
    },
    "ambiguity": {
      "type": "string",
      "minLength": 1
    },
    "handling_reason": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "missing_policy": {
      "type": "string"
    }
  }
}
