{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skillgate:schema:normalized-skill-input:v1",
  "title": "SkillGate NormalizedSkillInput",
  "description": "Skill-ready input artifact produced before target skill activation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "skill_id",
    "skill_name",
    "raw_request",
    "human_provided_inputs",
    "agent_discoverable_inputs",
    "safe_defaults",
    "requires_authorization",
    "blocked",
    "execution_constraints",
    "decision_kind",
    "decision_reason",
    "activation_instruction",
    "expected_output",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "skillgate.normalized_skill_input.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "skill_id": {
      "type": "string",
      "minLength": 1
    },
    "skill_name": {
      "type": "string",
      "minLength": 1
    },
    "raw_request": {
      "type": "string",
      "minLength": 1
    },
    "human_provided_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_slot_state"
      }
    },
    "agent_discoverable_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_slot_state"
      }
    },
    "safe_defaults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_slot_state"
      }
    },
    "requires_authorization": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_slot_state"
      }
    },
    "blocked": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_slot_state"
      }
    },
    "execution_constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_slot_state"
      }
    },
    "decision_kind": {
      "enum": [
        "ask_user",
        "assume_and_continue",
        "block_unsafe",
        "compile_directly",
        "explore_first"
      ]
    },
    "decision_reason": {
      "type": "string",
      "minLength": 1
    },
    "activation_instruction": {
      "type": "string",
      "minLength": 1
    },
    "expected_output": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    }
  },
  "$defs": {
    "input_slot_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "name",
        "text",
        "description",
        "category",
        "status",
        "value",
        "question",
        "assumption",
        "evidence_ids",
        "answer_source",
        "support",
        "risk",
        "ambiguity",
        "handling_reason",
        "confidence"
      ],
      "properties": {
        "schema_version": {
          "const": "skillgate.input_slot_state.v1"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "enum": [
            "agent_discoverable",
            "blocked",
            "human_askable",
            "irrelevant",
            "known",
            "requires_authorization",
            "safe_assumption"
          ]
        },
        "status": {
          "enum": [
            "agent_discoverable",
            "blocked",
            "human_askable",
            "irrelevant",
            "known",
            "requires_authorization",
            "safe_assumption"
          ]
        },
        "value": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "question": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "assumption": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "answer_source": {
          "enum": [
            "agent",
            "authorization",
            "blocked",
            "human",
            "human_or_agent",
            "known",
            "policy_default"
          ]
        },
        "support": {
          "enum": [
            "explicit",
            "guessed",
            "inferred",
            "recommended"
          ]
        },
        "risk": {
          "type": "string",
          "minLength": 1
        },
        "ambiguity": {
          "type": "string",
          "minLength": 1
        },
        "handling_reason": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "missing_policy": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_kind",
        "source_id",
        "path",
        "line_start",
        "line_end",
        "quote",
        "quote_hash",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "enum": [
            "answer",
            "conversation",
            "inferred",
            "policy",
            "repo_config",
            "repo_file",
            "runtime",
            "skill",
            "user"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "line_start": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "line_end": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "quote": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "quote_hash": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    }
  }
}
